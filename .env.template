# ── Swing Signal Engine — .env template ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Email delivery ────────────────────────────────────────────────────────────
EMAIL_SENDER=your.gmail@gmail.com        # Gmail address to send from
EMAIL_PASSWORD=your_16_char_app_password  # Gmail App Password (not your login password)
EMAIL_RECIPIENT=you@example.com           # Where to receive signal reports

# How to get a Gmail App Password:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search for "App passwords"
#   4. Create a new app password for "Mail" on "Windows Computer"
#   5. Use the 16-character password here

# ── Telegram delivery ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz  # From @BotFather
TELEGRAM_CHAT_ID=987654321                                  # Your chat ID

# How to set up Telegram:
#   1. Message @BotFather on Telegram, create a new bot, copy the token
#   2. Message your new bot, then visit:
#      https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   3. Find "chat": {"id": 12345} in the response — that's your chat ID

# ── Portfolio ─────────────────────────────────────────────────────────────────
PORTFOLIO_VALUE=750000    # Combined Rollover IRA + Roth IRA value
                          # Update this when your account value changes significantly

# ── Signal thresholds ─────────────────────────────────────────────────────────
SWING_MIN_CONVICTION=65         # Minimum technical conviction to show BUY signal (0-100)
SWING_COOLDOWN_DAYS=60          # Days before re-signaling after a SELL
SWING_FORCE_SELL_CONVICTION=85  # Bypass cooldown if conviction >= this on SELL
AI_MIN_CONFIDENCE=0.55          # Minimum AI confidence to include signal in report
